{
  "settings": {
    "analysis": {
      "analyzer": {
        "nori_analyzer": {
          "type": "custom",
          "tokenizer": "nori_tokenizer",
          "filter": ["lowercase", "nori_part_of_speech"]
        }
      },
      "filter": {
        "nori_part_of_speech": {
          "type": "nori_part_of_speech",
          "stoptags": ["E", "J", "SC", "SE", "SF", "SP", "SSC", "SSO", "SY", "VCN", "VCP", "VSV", "VX", "XPN", "XSA", "XSN", "XSV"]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "messageId":         { "type": "long" },
      "chatRoomId":        { "type": "long" },
      "senderId":          { "type": "long" },
      "senderName":        { "type": "keyword" },
      "content":           { "type": "text", "analyzer": "nori_analyzer" },
      "originalFilename":  { "type": "text", "analyzer": "nori_analyzer" },
      "messageType":       { "type": "keyword" },
      "deleted":           { "type": "boolean" },
      "createdAt":         { "type": "date" }
    }
  }
}
